{
  "name": "freedash-pc",
  "version": "0.1.0",
  "description": "Frontend launcher para o emulador Xenia (Xbox 360), inspirado no Freestyle Dash",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently -k \"vite dev\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "conf": "^15.1.0",
    "electron-store": "^8.2.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.kaua.freedash",
    "productName": "FreeDash",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png"
    }
  },
  "author": "Kauã Keven",
  "license": "MIT"
}
